# ─────────────────────────────────────────────────────────────────────────
# Eldervale RPG — environment configuration
# Copy to `.env` for local dev. The seam (shared/factory.py) reads these.
# NOTE: do NOT put inline comments after a value — the whole line after `=`
# is taken as the value. Keep comments on their own lines.
# ─────────────────────────────────────────────────────────────────────────

# Which set of implementations to wire up: "local" or "azure"
RUNTIME=local

# ── LLM provider (local runtime) ────────────────────────────────────────
# One of: mock | openai | azure_openai | ollama
#   mock         : canned deterministic responses, no network, no keys
#   openai       : OpenAI API   (set OPENAI_API_KEY)
#   azure_openai : Azure OpenAI (set AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY)
#   ollama       : local Ollama OpenAI-compatible endpoint (free, offline)
LLM_PROVIDER=mock

# Model for the 5 character agents (cheap/fast) and the GM narrator (stronger).
CHARACTER_MODEL=gpt-4o-mini
NARRATOR_MODEL=gpt-4o-mini

OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── Game tuning ──────────────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=5
MAX_AGENTS_PER_TURN=4
HISTORY_SUMMARIZE_EVERY=10
# Set DICE_SEED to an integer for deterministic rolls (tests); leave blank for random.
DICE_SEED=

# ── Local stores ─────────────────────────────────────────────────────────
SQLITE_PATH=.data/eldervale.db
KNOWLEDGE_DIR=knowledge

# ── Auth (local) ─────────────────────────────────────────────────────────
DEV_AUTH_SECRET=dev-only-secret-change-me
# Set DEV_AUTH_BYPASS=false to exercise real token validation / isolation tests.
DEV_AUTH_BYPASS=true
DEV_USER_ID=dev-user-0001

# ── Azure runtime (Phase 5 — leave blank for local) ──────────────────────
FOUNDRY_PROJECT_ENDPOINT=
CHARACTER_AGENT_IDS=
NARRATOR_AGENT_ID=
FOUNDRY_IQ_INDEX=eldervale-campaign
COSMOS_DB_ENDPOINT=
COSMOS_DB_DATABASE=fantasy-rpg
COSMOS_USERS_CONTAINER=users
COSMOS_SESSIONS_CONTAINER=sessions
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Which JWT claim holds the user id — verify against a real token: sub vs oid.
ENTRA_USER_ID_CLAIM=sub
